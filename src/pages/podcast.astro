---
import Base from "../layouts/Base.astro";

const episodes = [
	{
		title: "对自己的能力应该相信多少，又该对自身有多少怀疑",
		description:
			"本期嘉宾 空远：登山与徒步爱好者。曾完成勒多曼因徒步、玉珠峰攀登、尼泊尔 ABC 等高海拔长线徒步。这次五一他原本计划在 12 小时内完成四姑娘山大二峰连登，却在离顶峰仅百米时被迫撤退，进而引发了他的更多思考，并且决定封山不爬了。",
		url: "https://www.xiaoyuzhoufm.com/episode/6a3e38382e335a35a809c70e",
	},
	{
		title: "她怕被 AI 取代，他一次性开六个 Terminal",
		description:
			"这一期从主播的 AI 焦虑出发，和在一线做 AI infra 的工程师大头聊开了——从 AI 工具聊到寺庙禅修，从乐队排练室聊到脱口秀。偶尔严肃，经常跑题。本期嘉宾大头：AI Infra / Agent 工程师，贝斯手，退役脱口秀演员，六窗口并行工作流重度 AI 用户。",
		url: "https://www.xiaoyuzhoufm.com/episode/6a159102ff7b9a8c0a5b88e5",
	},
	{
		title: "如果不确定要不要做，那就先去做吧",
		description:
			"这是一期没有主题的漫谈。但也许你会觉得，这两个人的脑子还是有点奇奇怪怪的有趣的东西在里面的。",
		url: "https://www.xiaoyuzhoufm.com/episode/69e0db9bb977fb2c471f5122",
	},
];
---

<Base
	title="Chen Wang｜世界的有趣，我很好奇"
	description="十方上下是一档对世界保持好奇的播客。世界的有趣，我很好奇。"
	active="podcast"
>
	<main class="page-shell">
		<section class="hero" aria-labelledby="page-title">
			<div class="hero-copy">
				<p class="eyebrow">PODCAST · Ten Thousand Worlds</p>
				<h1 id="page-title">十方上下</h1>
				<p class="intro">世界的有趣，我很好奇</p>
				<a class="primary-cta" href="https://www.xiaoyuzhoufm.com/podcast/69d60008e3ebaaa4b469a98d" target="_blank" rel="noreferrer">
					去小宇宙查看 <span aria-hidden="true">↗</span>
				</a>
			</div>
			<div class="hero-logo" aria-hidden="true"><span></span></div>
			<div class="hero-note">
				<p class="eyebrow">In the wilderness</p>
				<p>在人生的旷野中，你看见了什么</p>
			</div>
		</section>

		<section class="featured" id="featured" aria-labelledby="featured-title">
			<div class="section-heading">
				<div>
					<p class="eyebrow">01 · FEATURED EPISODES</p>
					<h2 id="featured-title">精选内容</h2>
				</div>
				<p class="section-intro">不同人生里的判断、犹疑与选择。</p>
			</div>

			<div class="episode-list">
				{episodes.map((episode, index) => (
					<article class="episode">
						<div class="episode-meta">
							<span>EPISODE</span>
							<span>{String(index + 1).padStart(2, "0")}</span>
						</div>
						<div class="episode-visual" aria-hidden="true">
							<div class="mini-logo"><span></span></div>
						</div>
						<div class="episode-copy">
							<h3>{episode.title}</h3>
							<p>{episode.description}</p>
							<a class="episode-link" href={episode.url} target="_blank" rel="noreferrer">
								<span class="play-icon" aria-hidden="true">▶</span>
								前往小宇宙播放
							</a>
						</div>
					</article>
				))}
			</div>
		</section>

		<section class="guest" id="guest" aria-labelledby="guest-title">
			<div>
				<p class="eyebrow">02 · BE OUR GUEST</p>
				<h2 id="guest-title">也想来聊聊？</h2>
			</div>
			<div class="guest-action">
					<p>如果你有一段独特的经历、一个正在探索的问题，欢迎来聊天。</p>
					<a
						class="guest-cta"
						href="https://my.feishu.cn/share/base/form/shrcnQjC4QOzAjLB0hu8RL3d6Ed"
						target="_blank"
						rel="noreferrer"
					>
						我想来聊聊 <span aria-hidden="true">↗</span>
					</a>
			</div>
		</section>
	</main>
</Base>

<style>
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(180px, 0.75fr) minmax(180px, 0.65fr);
		align-items: center;
		gap: var(--spacing-40);
		min-height: 620px;
		padding-block: 96px;
	}

	.episode-meta {
		margin: 0 0 var(--spacing-12);
		font-family: var(--font-geist-mono);
		font-size: var(--text-eyebrow);
		line-height: var(--leading-eyebrow);
		letter-spacing: var(--tracking-label);
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		margin-bottom: var(--spacing-20);
		font-size: clamp(48px, 6.5vw, 84px);
		font-weight: 600;
		line-height: 1.1;
		letter-spacing: 0.04em;
	}

	.intro {
		margin-bottom: var(--spacing-32);
		color: var(--color-charcoal);
		font-family: var(--font-wenkai);
		font-size: 22px;
		line-height: 1.6;
	}

	.primary-cta,
	.guest-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: var(--spacing-12);
		height: var(--button-height);
		padding-inline: var(--spacing-20);
		border: 0;
		border-radius: var(--radius-button);
		font-size: 14px;
		font-weight: var(--font-weight-regular);
	}

	.primary-cta {
		color: var(--color-pure-white);
		background: var(--color-obsidian);
		text-decoration: none;
	}

	.primary-cta span {
		font-family: var(--font-geist-mono);
	}

	.hero-logo,
	.mini-logo {
		display: grid;
		place-items: center;
		border: 1px solid var(--color-carbon);
		border-radius: var(--radius-pill);
	}

	.hero-logo span,
	.mini-logo span {
		width: 70%;
		height: 70%;
		border: 1px solid var(--color-carbon);
	}

	.hero-logo {
		width: min(100%, 260px);
		aspect-ratio: 1;
		justify-self: center;
		transition: transform 700ms cubic-bezier(0.4, 0, 0.2, 1);
	}

	.hero-note {
		align-self: end;
		padding-bottom: var(--spacing-24);
	}

	.hero-note > p:last-child,
	.section-intro {
		margin: 0;
		color: var(--color-charcoal);
		font-size: 14px;
		line-height: 1.7;
	}

	.featured {
		padding-block: var(--spacing-section);
	}

	h2 {
		margin-bottom: 0;
		font-size: clamp(34px, 4.2vw, 48px);
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: 0.02em;
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: var(--spacing-32);
		margin-bottom: var(--spacing-44);
	}

	.section-intro {
		max-width: 310px;
	}

	.episode-list {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--spacing-20);
	}

	.episode {
		display: flex;
		min-width: 0;
		flex-direction: column;
		padding: var(--card-padding);
		border-radius: var(--radius-card);
		background: var(--color-pure-white);
		box-shadow: var(--shadow-subtle);
	}

	.episode-meta {
		display: flex;
		justify-content: space-between;
		color: var(--color-stone);
	}

	.episode-visual {
		display: grid;
		min-height: 210px;
		place-items: center;
		margin-bottom: var(--spacing-24);
		border-radius: var(--radius-card);
		background: var(--color-paper-white);
		box-shadow: var(--shadow-hairline);
	}

	.mini-logo {
		width: 96px;
		aspect-ratio: 1;
	}

	.episode-copy {
		display: flex;
		flex: 1;
		flex-direction: column;
	}

	h3 {
		margin-bottom: var(--spacing-16);
		font-family: var(--font-source-han-serif);
		font-size: clamp(20px, 1.8vw, 24px);
		font-weight: 600;
		line-height: 1.5;
		letter-spacing: 0.01em;
	}

	.episode-copy > p {
		display: -webkit-box;
		overflow: hidden;
		margin-bottom: var(--spacing-24);
		color: var(--color-stone);
		font-size: var(--text-caption);
		line-height: 1.8;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 4;
	}

	.episode-link {
		display: flex;
		align-items: center;
		gap: var(--spacing-8);
		width: fit-content;
		margin-top: auto;
		color: var(--color-charcoal);
		font-size: var(--text-caption);
		text-decoration: none;
	}

	.play-icon {
		display: grid;
		width: 22px;
		height: 22px;
		place-items: center;
		border-radius: var(--radius-pill);
		color: var(--color-obsidian);
		box-shadow: 0 0 0 1px var(--color-ash);
		font-size: 7px;
	}

	.guest {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-40);
		margin-block: var(--spacing-section);
		padding: clamp(var(--spacing-32), 6vw, 80px);
		border-radius: var(--radius-card);
		color: var(--color-pure-white);
		background: var(--color-obsidian);
	}

	.guest h2 {
		color: var(--color-pure-white);
	}

	.guest-action {
		align-self: end;
	}

	.guest-action > p {
		max-width: 520px;
		margin-bottom: var(--spacing-24);
		color: var(--color-ash);
		line-height: 1.8;
	}

	.guest-cta {
		color: var(--color-obsidian);
		background: var(--color-pure-white);
		text-decoration: none;
	}

	@media (hover: hover) {
		.hero-logo:hover {
			transform: rotate(90deg);
		}

		.episode-link {
			transition: color 160ms ease;
		}

		.episode-link:hover {
			color: var(--color-obsidian);
		}

		.primary-cta,
		.guest-cta {
			transition:
				transform 160ms ease,
				opacity 160ms ease;
		}

		.primary-cta:hover,
		.guest-cta:hover {
			transform: translateY(-1px);
			opacity: 0.88;
		}
	}

	@media (max-width: 960px) {
		.hero {
			grid-template-columns: 1fr 0.7fr;
		}

		.hero-note {
			display: none;
		}

		.episode-list {
			grid-template-columns: 1fr;
		}

		.episode {
			display: grid;
			grid-template-columns: 220px 1fr;
			gap: var(--spacing-24);
		}

		.episode-meta {
			grid-column: 1 / -1;
		}

		.episode-visual {
			min-height: 220px;
			margin-bottom: 0;
		}
	}

	@media (max-width: 680px) {
		:global(:root) {
			--spacing-section: 80px;
		}

		.hero {
			grid-template-columns: 1fr;
			gap: var(--spacing-44);
			min-height: auto;
			padding-block: 72px;
		}

		.hero-logo {
			grid-row: 1;
			width: min(58vw, 220px);
			justify-self: start;
		}

		.guest {
			grid-template-columns: 1fr;
		}

		.section-heading {
			align-items: start;
			flex-direction: column;
		}

		.episode {
			display: flex;
		}

		.episode-visual {
			min-height: 200px;
			margin-bottom: var(--spacing-24);
		}

		.guest {
			gap: var(--spacing-44);
		}
	}
</style>
