---
import { withBase } from "../lib/base";

interface Props {
	title: string;
	date: string;
	lead?: string;
	bodyHtml: string;
}

const { title, date, lead = "", bodyHtml } = Astro.props;
const dateLabel = date.replaceAll("-", ".");
const blogHref = withBase("/blog/");
---

<article class="article">
	<header class="article-hero">
		<a class="back-link" href={blogHref}>← Blog</a>
		<p class="eyebrow">ARTICLE · {dateLabel}</p>
		<h1>{title}</h1>
		{
			lead ? (
				<blockquote>
					<p>{lead}</p>
				</blockquote>
			) : null
		}
	</header>

	<div class="article-body" data-lightbox-root set:html={bodyHtml} />

	<footer class="article-footer">
		<a class="back-cta" href={blogHref}>← 返回 Blog</a>
	</footer>
</article>

<dialog class="lightbox" data-lightbox aria-label="查看大图">
	<button type="button" class="lightbox-close" data-lightbox-close aria-label="关闭">
		×
	</button>
	<button type="button" class="lightbox-nav lightbox-prev" data-lightbox-prev aria-label="上一张">
		‹
	</button>
	<button type="button" class="lightbox-nav lightbox-next" data-lightbox-next aria-label="下一张">
		›
	</button>
	<figure class="lightbox-figure">
		<img data-lightbox-img alt="" />
		<figcaption data-lightbox-caption hidden></figcaption>
	</figure>
</dialog>

<script>
	const root = document.querySelector<HTMLElement>("[data-lightbox-root]");
	const dialog = document.querySelector<HTMLDialogElement>("[data-lightbox]");
	const imgEl = document.querySelector<HTMLImageElement>("[data-lightbox-img]");
	const captionEl = document.querySelector<HTMLElement>("[data-lightbox-caption]");
	const closeBtn = document.querySelector<HTMLButtonElement>("[data-lightbox-close]");
	const prevBtn = document.querySelector<HTMLButtonElement>("[data-lightbox-prev]");
	const nextBtn = document.querySelector<HTMLButtonElement>("[data-lightbox-next]");

	if (root && dialog && imgEl && captionEl && closeBtn && prevBtn && nextBtn) {
		const images = [...root.querySelectorAll<HTMLImageElement>("img")];
		let index = 0;

		const show = (nextIndex: number) => {
			if (images.length === 0) return;
			index = (nextIndex + images.length) % images.length;
			const source = images[index];
			imgEl.src = source.currentSrc || source.src;
			imgEl.alt = source.alt || "";

			const caption =
				source.closest("figure")?.querySelector("figcaption")?.textContent?.trim() ||
				"";
			if (caption) {
				captionEl.textContent = caption;
				captionEl.hidden = false;
			} else {
				captionEl.textContent = "";
				captionEl.hidden = true;
			}

			const multi = images.length > 1;
			prevBtn.hidden = !multi;
			nextBtn.hidden = !multi;

			if (!dialog.open) dialog.showModal();
		};

		const close = () => {
			if (dialog.open) dialog.close();
		};

		for (const [i, image] of images.entries()) {
			image.classList.add("is-zoomable");
			image.setAttribute("role", "button");
			image.tabIndex = 0;
			image.setAttribute("aria-label", "点击查看大图");
			image.addEventListener("click", () => show(i));
			image.addEventListener("keydown", (event) => {
				if (event.key === "Enter" || event.key === " ") {
					event.preventDefault();
					show(i);
				}
			});
		}

		closeBtn.addEventListener("click", close);
		prevBtn.addEventListener("click", () => show(index - 1));
		nextBtn.addEventListener("click", () => show(index + 1));

		dialog.addEventListener("click", (event) => {
			const target = event.target;
			if (!(target instanceof Element)) return;
			// Close when clicking the dimmed mask, not the image / controls.
			if (
				target === dialog ||
				(!target.closest(".lightbox-figure") &&
					!target.closest(".lightbox-close") &&
					!target.closest(".lightbox-nav"))
			) {
				close();
			}
		});

		dialog.addEventListener("keydown", (event) => {
			if (!dialog.open) return;
			if (event.key === "ArrowLeft") {
				event.preventDefault();
				show(index - 1);
			} else if (event.key === "ArrowRight") {
				event.preventDefault();
				show(index + 1);
			}
		});
	}
</script>

<style>
	.article {
		width: min(100%, 880px);
		margin-inline: auto;
		padding-inline: var(--page-gutter);
		padding-bottom: var(--spacing-section);
	}

	.article-hero {
		padding-block: 72px 48px;
	}

	.back-link {
		display: inline-block;
		margin-bottom: var(--spacing-32);
		color: var(--color-stone);
		font-family: var(--font-geist-mono);
		font-size: var(--text-caption);
		letter-spacing: var(--tracking-label);
		text-decoration: none;
		text-transform: uppercase;
	}

	h1,
	:global(.article-body h2),
	:global(.article-body h3),
	:global(.article-body p),
	:global(.article-body ul),
	:global(.article-body ol) {
		margin-top: 0;
	}

	h1 {
		margin-bottom: var(--spacing-32);
		font-family: var(--font-source-han-serif);
		font-size: clamp(36px, 5vw, 56px);
		font-weight: 600;
		line-height: 1.25;
		letter-spacing: 0.01em;
	}

	blockquote {
		margin: 0;
		padding: 0;
		border: 0;
	}

	blockquote p {
		margin: 0;
		color: var(--color-charcoal);
		font-family: var(--font-wenkai);
		font-size: clamp(18px, 2vw, 22px);
		line-height: 1.7;
	}

	.article-body {
		color: var(--color-charcoal);
		font-size: 17px;
		line-height: 1.9;
	}

	:global(.article-body > p),
	:global(.article-body > ul),
	:global(.article-body > ol),
	:global(.article-body > blockquote),
	:global(.article-body .media-col > p) {
		margin-bottom: var(--spacing-24);
	}

	:global(.article-body h2) {
		margin: var(--spacing-44) 0 var(--spacing-24);
		font-family: var(--font-source-han-serif);
		font-size: clamp(26px, 3vw, 32px);
		font-weight: 600;
		line-height: 1.35;
		letter-spacing: 0.02em;
		color: var(--color-obsidian);
	}

	:global(.article-body h3) {
		margin: var(--spacing-32) 0 var(--spacing-16);
		font-family: var(--font-source-han-serif);
		font-size: clamp(20px, 2.4vw, 24px);
		font-weight: 600;
		line-height: 1.4;
		color: var(--color-obsidian);
	}

	:global(.article-body blockquote) {
		margin: 0 0 var(--spacing-24);
		padding-left: var(--spacing-16);
		border-left: 2px solid var(--color-ash);
		color: var(--color-charcoal);
		font-family: var(--font-wenkai);
	}

	:global(.article-body ul),
	:global(.article-body ol) {
		padding-left: 1.25em;
	}

	:global(.article-body li) {
		margin-bottom: var(--spacing-12);
	}

	:global(.article-body li::marker) {
		color: var(--color-ash);
	}

	:global(.article-body .media-row) {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-16);
		margin-block: var(--spacing-32);
	}

	:global(.article-body .media-col) {
		min-width: 0;
	}

	:global(.article-body .media) {
		margin: 0 0 var(--spacing-16);
	}

	:global(.article-body .media img) {
		display: block;
		width: 100%;
		height: auto;
		border-radius: var(--radius-card);
		background: var(--color-pure-white);
		box-shadow: var(--shadow-hairline);
	}

	:global(.article-body .media img.is-zoomable) {
		cursor: zoom-in;
	}

	:global(.article-body figcaption) {
		margin-top: var(--spacing-8);
		color: var(--color-stone);
		font-size: var(--text-caption);
		line-height: 1.5;
		text-align: center;
	}

	.lightbox {
		width: 100vw;
		height: 100vh;
		max-width: 100vw;
		max-height: 100vh;
		margin: 0;
		padding: 0;
		border: 0;
		background: rgb(0 0 0 / 82%);
		color: var(--color-pure-white);
		overflow: hidden;
	}

	.lightbox::backdrop {
		background: transparent;
	}

	.lightbox-figure {
		display: grid;
		gap: var(--spacing-12);
		margin: 0;
		min-height: 100%;
		place-content: center;
		justify-items: center;
		pointer-events: none;
	}

	.lightbox-figure img,
	.lightbox-figure figcaption {
		pointer-events: auto;
	}

	.lightbox-figure img {
		display: block;
		max-width: min(92vw, 1200px);
		max-height: min(82vh, 900px);
		width: auto;
		height: auto;
		object-fit: contain;
		border-radius: var(--radius-card);
		background: var(--color-obsidian);
		box-shadow: 0 16px 48px rgb(0 0 0 / 35%);
	}

	.lightbox-figure figcaption {
		max-width: min(92vw, 720px);
		margin: 0;
		color: rgb(255 255 255 / 78%);
		font-size: var(--text-caption);
		line-height: 1.6;
		text-align: center;
	}

	.lightbox-close,
	.lightbox-nav {
		position: fixed;
		z-index: 2;
		display: grid;
		place-items: center;
		border: 0;
		border-radius: var(--radius-pill);
		background: rgb(255 255 255 / 12%);
		color: var(--color-pure-white);
		cursor: pointer;
		backdrop-filter: blur(10px);
	}

	.lightbox-close {
		top: 20px;
		right: 20px;
		width: 44px;
		height: 44px;
		font-size: 28px;
		line-height: 1;
	}

	.lightbox-nav {
		top: 50%;
		width: 44px;
		height: 44px;
		font-size: 32px;
		line-height: 1;
		transform: translateY(-50%);
	}

	.lightbox-prev {
		left: 16px;
	}

	.lightbox-next {
		right: 16px;
	}

	.article-footer {
		margin-top: var(--spacing-44);
		padding-top: var(--spacing-32);
		border-top: 1px solid var(--color-hairline);
	}

	.back-cta {
		display: inline-flex;
		align-items: center;
		height: var(--button-height);
		padding-inline: var(--spacing-20);
		border-radius: var(--radius-button);
		color: var(--color-pure-white);
		background: var(--color-obsidian);
		font-size: 14px;
		text-decoration: none;
	}

	@media (hover: hover) {
		.back-link,
		.back-cta,
		.lightbox-close,
		.lightbox-nav {
			transition:
				color 160ms ease,
				opacity 160ms ease,
				transform 160ms ease,
				background 160ms ease;
		}

		.back-link:hover {
			color: var(--color-obsidian);
		}

		.back-cta:hover {
			transform: translateY(-1px);
			opacity: 0.88;
		}

		:global(.article-body .media img.is-zoomable:hover) {
			opacity: 0.92;
		}

		.lightbox-close:hover,
		.lightbox-nav:hover {
			background: rgb(255 255 255 / 22%);
		}
	}

	@media (max-width: 720px) {
		.article-hero {
			padding-block: 48px 32px;
		}

		:global(.article-body .media-row) {
			flex-direction: column;
		}

		:global(.article-body .media-col) {
			max-width: 100% !important;
			flex: 1 1 auto !important;
		}

		.lightbox-nav {
			top: auto;
			bottom: 20px;
			transform: none;
		}

		.lightbox-prev {
			left: calc(50% - 56px);
		}

		.lightbox-next {
			right: calc(50% - 56px);
			left: auto;
		}
	}
</style>
